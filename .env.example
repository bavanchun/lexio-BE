# DEV ONLY — never use these credentials in staging or production.
# Copy to .env before running: cp .env.example .env
# .env is gitignored and must never be committed.

POSTGRES_USER=lexio
POSTGRES_PASSWORD=devpass
POSTGRES_DB=postgres

MONGO_INITDB_ROOT_USERNAME=lexio
MONGO_INITDB_ROOT_PASSWORD=devpass

RABBITMQ_DEFAULT_USER=lexio
RABBITMQ_DEFAULT_PASS=devpass

ELASTIC_PASSWORD=devpass

# Fixed dev CLUSTER_ID — must stay constant across restarts on the same volume.
# If you wipe the volume (docker compose down -v), the value resets automatically.
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
